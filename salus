#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# Salus — full stack management via docker compose
#
#   ./salus up      build images + start all services
#   ./salus down    stop + remove all containers
#   ./salus logs    follow logs for all services
#   ./salus build   rebuild images without restarting
# ──────────────────────────────────────────────────────────────────────────────

CMD="${1:-}"

log() { echo "[salus] $*"; }
err() { echo "[salus] ERROR: $*" >&2; }

case "$CMD" in
  build)
    log "Building images..."
    docker compose build
    ;;

  up)
    log "Starting all services..."
    docker compose up -d --build
    ;;

  down)
    log "Stopping all services..."
    docker compose down
    ;;

  logs)
    docker compose logs -f
    ;;

  *)
    err "Unknown command: ${CMD:-<none>}"
    echo ""
    echo "Usage:"
    echo "  ./salus up      build + start all services"
    echo "  ./salus down    stop all services"
    echo "  ./salus logs    follow logs"
    echo "  ./salus build   rebuild images"
    exit 1
    ;;
esac
