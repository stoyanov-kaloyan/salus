#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# Salus — proxy management
#
#   ./salus up      build image + start proxy on :8080
#   ./salus down    stop + remove the proxy container
#   ./salus logs    follow proxy logs
#   ./salus build   rebuild image without restarting
# ──────────────────────────────────────────────────────────────────────────────

IMAGE="salus/proxy:latest"
CONTAINER="salus-proxy"
CERTS_VOL="salus-proxy-certs"
CMD="${1:-}"

log() { echo "[salus] $*"; }
err() { echo "[salus] ERROR: $*" >&2; }

build() {
  log "Building $IMAGE..."
  docker build -t "$IMAGE" proxy/
}

case "$CMD" in
  build)
    build
    ;;

  up)
    build
    docker rm -f "$CONTAINER" 2>/dev/null || true
    log "Starting proxy on :8080..."
    docker run -d \
      --name "$CONTAINER" \
      -p 8080:8080 \
      -v "${CERTS_VOL}:/certs" \
      -e PROXY_SETUP_HOST="salus.proxy" \
      -e DETERMINISTIC_CALIBRATION_PATH="/app/deterministic_calibration.json" \
      "$IMAGE"
    log "Proxy running. Setup page: http://salus.proxy (via proxy) or http://localhost:8080"
    ;;

  down)
    docker rm -f "$CONTAINER" 2>/dev/null && log "Proxy stopped." || log "Nothing to stop."
    ;;

  logs)
    docker logs -f "$CONTAINER"
    ;;

  *)
    err "Unknown command: ${CMD:-<none>}"
    echo ""
    echo "Usage:"
    echo "  ./salus up      build + start proxy on :8080"
    echo "  ./salus down    stop proxy"
    echo "  ./salus logs    follow proxy logs"
    echo "  ./salus build   rebuild image"
    exit 1
    ;;
esac
