# =============================================================================
# Salus Content Moderation API – environment variables
# Copy this file to .env and fill in real values before running the server.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL – found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service-role secret key (server-side only, bypasses Row-Level Security).
# Found in: Supabase Dashboard → Settings → API → Project API keys → service_role
# WARNING: Never expose this key client-side or commit it to source control.
SUPABASE_KEY=your-service-role-secret-key

# -----------------------------------------------------------------------------
# Deepfake model
# -----------------------------------------------------------------------------
# Backend to use: "auto" (PyTorch if available, else ONNX), "pytorch", or "onnx"
DEEPFAKE_MODEL_BACKEND=auto

# Absolute or relative path to the .pt checkpoint file.
# Defaults to deepfake_resnet18_best.pt in the same directory as api.py.
DEEPFAKE_PT_CHECKPOINT_PATH=deepfake_resnet18_best.pt

# Decision threshold for the deepfake score (0–1).  Defaults to the value
# stored inside the checkpoint, or 0.5 if absent.
DEEPFAKE_THRESHOLD=0.5

# CUDA device index for the deepfake model (-1 = CPU)
DEEPFAKE_DEVICE=0

# -----------------------------------------------------------------------------
# Flux.1 detector
# -----------------------------------------------------------------------------
FLUX_MODEL_NAME=prithivMLmods/OpenSDI-Flux.1-SigLIP2
FLUX_THRESHOLD=0.5
FLUX_DEVICE=0

# -----------------------------------------------------------------------------
# Server (uvicorn)
HOST=0.0.0.0
PORT=8000
